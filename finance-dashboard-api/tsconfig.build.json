{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "types": [
            "node"
        ],
        "rootDir": "src",
        "outDir": "dist/src"
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/tests",
        "**/*.test.ts"
    ]
}