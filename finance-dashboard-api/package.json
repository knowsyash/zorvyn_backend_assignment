{
    "name": "finance-dashboard-api",
    "version": "1.0.0",
    "description": "Finance Dashboard Backend API using Node.js, Express, TypeScript, MongoDB (Mongoose), and JWT",
    "main": "dist/src/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/src/server.js",
        "smoke": "node scripts/smoke-test.js",
        "smoke:4020": "node scripts/smoke-test.js http://localhost:4020",
        "test": "jest --runInBand --forceExit",
        "test:watch": "jest --watch --runInBand --forceExit",
        "test:coverage": "jest --coverage --runInBand --forceExit"
    },
    "keywords": [
        "finance",
        "dashboard",
        "api",
        "express",
        "typescript",
        "mongodb",
        "mongoose"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.8",
        "@types/morgan": "^1.9.9",
        "@types/node": "^22.13.1",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.12.2",
        "morgan": "^1.10.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "typescript": "^5.8.2",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/supertest": "^6.0.3",
        "jest": "^30.0.0",
        "mongodb-memory-server": "^10.1.4",
        "supertest": "^7.1.4",
        "ts-jest": "^29.4.1",
        "tsx": "^4.19.2"
    },
    "engines": {
        "node": ">=20"
    }
}